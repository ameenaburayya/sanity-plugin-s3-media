{
  "name": "sanity-plugin-s3-media",
  "version": "2.0.2",
  "description": "Adding the ability to have s3 bucket stored media",
  "packageManager": "pnpm@10.10.0",
  "keywords": [
    "sanity",
    "sanity-plugin"
  ],
  "license": "MIT",
  "author": "Ameen Aburayya <a.aburayya95@gmail.com>",
  "repository": {
    "type": "git",
    "url": "https://github.com/ameenaburayya/sanity-plugin-s3-media.git"
  },
  "sideEffects": false,
  "type": "commonjs",
  "exports": {
    ".": {
      "source": "./src/index.ts",
      "import": "./dist/index.mjs",
      "default": "./dist/index.js"
    },
    "./client": {
      "source": "./src/client.ts",
      "import": "./dist/client.mjs",
      "default": "./dist/client.js"
    },
    "./package.json": "./package.json"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist",
    "sanity.json",
    "v2-incompatible.js"
  ],
  "scripts": {
    "build": "pnpm --filter sanity-plugin-s3-media-asset-utils run build && plugin-kit verify-package --silent && pkg-utils build --strict --check --clean",
    "build:all": "pnpm -r --filter './packages/**' --if-present --sort run build && pnpm run build",
    "changeset": "changeset",
    "format": "prettier --write --cache --ignore-unknown .",
    "lint:all": "pnpm run lint && pnpm -r --filter './packages/**' --if-present lint && pnpm run typecheck:all",
    "lint:ci": "pnpm run lint:all",
    "typecheck": "pnpm exec tsc -p tsconfig.json --noEmit",
    "typecheck:all": "pnpm run typecheck && pnpm -r --filter './packages/**' exec tsc -p tsconfig.json --noEmit",
    "link-watch": "plugin-kit link-watch",
    "lint": "eslint .",
    "pack:check": "npm pack --dry-run && pnpm --filter sanity-plugin-s3-media-asset-utils exec npm pack --dry-run",
    "prepare": "husky",
    "test": "vitest run",
    "test:all": "pnpm run test && pnpm -r --filter './packages/**' --if-present test",
    "test:ci": "pnpm run test:coverage:all",
    "test:coverage": "vitest run --coverage",
    "test:coverage:all": "pnpm run test:coverage && pnpm -r --filter './packages/**' --if-present test:coverage",
    "prepublishOnly": "pnpm run build",
    "release": "changeset publish",
    "version-packages": "changeset version",
    "watch": "pkg-utils watch --strict"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.6.0",
    "@sanity/client": "^7.13.2",
    "@sanity/color": "^3.0.6",
    "@sanity/icons": "^3.7.0",
    "@sanity/incompatible-plugin": "^1.0.5",
    "@sanity/studio-secrets": "^3.0.3",
    "@sanity/ui": "^3.0.5",
    "@sanity/uuid": "^3.0.2",
    "@tanem/react-nprogress": "^5.0.55",
    "copy-to-clipboard": "^3.3.1",
    "date-fns": "^4.0.0",
    "exif-component": "^1.0.1",
    "filesize": "^11.0.13",
    "groq": "^3.0.0",
    "is-hotkey": "^0.2.0",
    "lodash": "^4.17.23",
    "pluralize": "^8.0.0",
    "react-dropzone": "^11.3.1",
    "react-file-icon": "^1.6.0",
    "react-redux": "^9.2.0",
    "react-rx": "^4.2.2",
    "react-virtuoso": "^4.12.5",
    "redux": "^5.0.1",
    "redux-observable": "3.0.0-rc.2",
    "rxjs": "^7.8.1",
    "sanity": "^5",
    "styled-components": "^6.3.8"
  },
  "devDependencies": {
    "@babel/parser": "^7.29.0",
    "@changesets/cli": "^2.29.6",
    "@commitlint/cli": "^20.4.1",
    "@commitlint/config-conventional": "^20.4.1",
    "@eslint/js": "^9.39.2",
    "@sanity/pkg-utils": "^10.4.4",
    "@sanity/plugin-kit": "^4.0.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/is-hotkey": "^0.1.10",
    "@types/lodash": "^4.17.23",
    "@types/node": "^25.2.0",
    "@types/pluralize": "^0.0.33",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@types/react-file-icon": "^1.0.4",
    "@types/react-is": "^19.2.0",
    "@typescript-eslint/eslint-plugin": "^8.54.0",
    "@typescript-eslint/parser": "^8.54.0",
    "@vitest/coverage-v8": "^2.1.9",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-config-sanity": "^7.1.4",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-simple-import-sort": "^12.1.1",
    "eslint-plugin-unused-imports": "^4.3.0",
    "eslint-plugin-vitest": "^0.5.4",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-packagejson": "^3.0.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-is": "^19.2.4",
    "rimraf": "^3.0.2",
    "sanity-plugin-s3-media-asset-utils": "workspace:^",
    "sanity-plugin-s3-media-types": "workspace:*",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.1.1",
    "vitest": "^2.1.9"
  },
  "peerDependencies": {
    "react": "^19",
    "react-dom": "^19",
    "react-is": "^19",
    "sanity": "^5",
    "styled-components": "^6.3.8"
  },
  "engines": {
    "node": ">=18"
  },
  "sanityPlugin": {
    "verifyPackage": {
      "eslintImports": false
    }
  }
}
